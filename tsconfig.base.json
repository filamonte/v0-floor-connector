{
  "$schema": "https://json.schemastore.org/tsconfig",
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "allowJs": false,
    "checkJs": false,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "incremental": true,
    "jsx": "preserve",
    "baseUrl": ".",
    "paths": {
      "@floorconnector/config": ["packages/config/src/index.ts"],
      "@floorconnector/db": ["packages/db/src/index.ts"],
      "@floorconnector/domain": ["packages/domain/src/index.ts"],
      "@floorconnector/integrations": ["packages/integrations/src/index.ts"],
      "@floorconnector/types": ["packages/types/src/index.ts"],
      "@floorconnector/ui": ["packages/ui/src/index.ts"],
      "@/*": ["apps/web/*"]
    }
  }
}
