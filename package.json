{
  "name": "floorconnector",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@9.12.3",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "turbo run dev --filter=@floorconnector/web",
    "build": "turbo run build",
    "e2e": "playwright test",
    "e2e:auth": "playwright test --project=setup",
    "e2e:portal": "playwright test --project=chromium-portal",
    "e2e:portal-auth": "playwright test --project=setup-portal",
    "e2e:portal-fixture": "node scripts/portal-e2e-fixture.mjs",
    "e2e:second-tenant-fixture": "node scripts/e2e-second-tenant-fixture.mjs",
    "e2e:second-tenant-fixture:write": "node scripts/e2e-second-tenant-fixture.mjs --write",
    "e2e:payments:portal": "playwright test e2e/portal-invoice-boundary.spec.js e2e/portal-invoice-checkout-start.spec.js --project=chromium-portal",
    "e2e:payments:webhook": "playwright test e2e/stripe-webhook-reconciliation.spec.js --project=chromium-portal",
    "e2e:payments": "playwright test e2e/portal-invoice-boundary.spec.js e2e/portal-invoice-checkout-start.spec.js e2e/stripe-webhook-reconciliation.spec.js --project=chromium-portal",
    "e2e:super-admin": "playwright test --project=chromium-super-admin-access",
    "e2e:headed": "playwright test --headed",
    "lint": "turbo run lint",
    "demo:data:inventory": "node scripts/demo-data-inventory.mjs",
    "demo:data:seed:dry-run": "node scripts/seed-staging-demo-data.mjs --dry-run",
    "demo:data:seed:validate-target": "node scripts/seed-staging-demo-data.mjs --validate-target",
    "devtools:link": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/link-worktree-dev-tools.ps1",
    "devtools:link:fix": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/link-worktree-dev-tools.ps1 -Fix",
    "tooling:baseline": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/tooling-baseline.ps1",
    "setup:gh": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/setup-github-cli.ps1",
    "worktree:doctor": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/worktree-doctor.ps1",
    "worktree:create": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/create-worktree.ps1",
    "worktree:status": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/worktree-status.ps1",
    "worktree:reconcile": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/worktree-reconcile.ps1",
    "worktree:finish": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/finish-worktree.ps1",
    "worktree:audit": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/worktree-audit.ps1",
    "wave:review": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/wave-review.ps1",
    "wave:pr": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/wave-pr.ps1",
    "wave:status": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/wave-status.ps1",
    "auth:refresh": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/refresh-playwright-auth.ps1",
    "codex:streams": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/codex-streams.ps1",
    "codex:next": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/codex-next.ps1",
    "platform-admin": "node scripts/platform-admin.mjs",
    "staging:preflight": "node scripts/staging-preflight.mjs",
    "typecheck": "turbo run typecheck",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "fc:status": "node scripts/fc-stream-status.mjs",
    "fc:preflight:fast": "node scripts/fc-preflight.mjs fast",
    "fc:preflight:full": "node scripts/fc-preflight.mjs full",
    "fc:task:create": "node scripts/fc-task-create.mjs",
    "fc:task:list": "node scripts/fc-task-list.mjs",
    "fc:task:summary": "node scripts/fc-task-summary.mjs",
    "fc:agent:run": "node scripts/fc-agent-runner.mjs",
    "fc:wave": "node scripts/fc-wave-runner.mjs run",
    "fc:wave:prepare": "node scripts/fc-wave-runner.mjs prepare",
    "fc:wave:status": "node scripts/fc-wave-runner.mjs status",
    "fc:wave:validate": "node scripts/fc-wave-runner.mjs validate",
    "fc:wave:merge-check": "node scripts/fc-wave-runner.mjs merge-check",
    "fc:wave:report": "node scripts/fc-wave-runner.mjs report",
    "fc:wave:snapshot": "node scripts/fc-wave-runner.mjs snapshot",
    "fc:wave:push-stream": "node scripts/fc-wave-runner.mjs push-stream",
    "fc:wave:finish-stream": "node scripts/fc-wave-runner.mjs finish-stream",
    "fc:wave:merge-pushed": "node scripts/fc-wave-runner.mjs merge-pushed",
    "fc:wave:generate": "node scripts/fc-wave-runner.mjs generate",
    "fc:wave:approve": "node scripts/fc-wave-runner.mjs approve",
    "fc:wave:merge": "node scripts/fc-wave-runner.mjs merge"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.49.4",
    "lucide-react": "^1.8.0",
    "zod": "^3.24.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.24.0",
    "@next/eslint-plugin-next": "^15.2.4",
    "@playwright/test": "^1.51.1",
    "@types/node": "^22.14.0",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "autoprefixer": "^10.4.21",
    "eslint": "^9.24.0",
    "eslint-config-prettier": "^10.1.2",
    "globals": "^16.0.0",
    "postcss": "^8.5.3",
    "prettier": "^3.5.3",
    "tailwindcss": "^3.4.17",
    "tsup": "^8.4.0",
    "tsx": "^4.19.3",
    "turbo": "^2.5.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.29.1"
  }
}
