# -----------------------------------------------------------------------------
# FloorConnector
# Root environment template for local development and deployed environments.
# Canonical repo: https://github.com/filamonte/v0-floor-connector.git
# Canonical branch: main
# Local source of truth for the web app: C:\FloorConnector\.env.local
# Do not commit real secrets to git.
# -----------------------------------------------------------------------------

# -----------------------------------------------------------------------------
# Public app and site URLs
# -----------------------------------------------------------------------------
# Local defaults should use fully qualified localhost URLs.
# Override these in Vercel with your live production domains.
NEXT_PUBLIC_APP_NAME=FloorConnector
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_MARKETING_URL=http://localhost:3000
NEXT_PUBLIC_SUPPORT_URL=http://localhost:3000/support
NEXT_PUBLIC_PRIVACY_POLICY_URL=http://localhost:3000/privacy-policy
NEXT_PUBLIC_TERMS_OF_SERVICE_URL=http://localhost:3000/terms-of-service
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com
NEXT_PUBLIC_SENTRY_DSN=

# -----------------------------------------------------------------------------
# Shared app secrets and runtime configuration
# -----------------------------------------------------------------------------
NODE_ENV=development
APP_ENV=local
APP_SECRET=replace-with-a-long-random-secret
SESSION_SECRET=replace-with-a-long-random-secret
ENCRYPTION_KEY=replace-with-a-32-byte-key
CRON_SECRET=replace-with-a-long-random-secret
INTERNAL_API_TOKEN=replace-with-a-long-random-secret

# -----------------------------------------------------------------------------
# Supabase - development
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL_DEV=
NEXT_PUBLIC_SUPABASE_ANON_KEY_DEV=
SUPABASE_SERVICE_ROLE_KEY_DEV=
SUPABASE_JWT_SECRET_DEV=
SUPABASE_DB_URL_DEV=
SUPABASE_DIRECT_URL_DEV=

# -----------------------------------------------------------------------------
# Supabase - production
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL_PROD=
NEXT_PUBLIC_SUPABASE_ANON_KEY_PROD=
SUPABASE_SERVICE_ROLE_KEY_PROD=
SUPABASE_JWT_SECRET_PROD=
SUPABASE_DB_URL_PROD=
SUPABASE_DIRECT_URL_PROD=

# -----------------------------------------------------------------------------
# Active runtime database and Supabase values used by the app
# Set these to the environment-specific values above in each environment.
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=
DIRECT_URL=

# -----------------------------------------------------------------------------
# Stripe
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=
# Endpoint signing secret for signed Stripe webhooks, including /api/stripe/saas-billing-webhook.
STRIPE_WEBHOOK_SECRET=
STRIPE_CONNECT_WEBHOOK_SECRET=
STRIPE_FOUNDER_PLAN_PRICE_ID=
STRIPE_PRICE_ID_BASE=

# -----------------------------------------------------------------------------
# Early access public intake
# -----------------------------------------------------------------------------
# Required in production for the public Request Early Access form.
# Must point to the existing canonical company that owns public intake leads.
FLOORCONNECTOR_EARLY_ACCESS_INTAKE_COMPANY_ID=

# Optional local QA widget for exposing the DEV MODE / Reset session helper.
# Leave unset for clean founder-demo screenshots.
FLOORCONNECTOR_SHOW_DEV_QA_TOOLS=

# Optional local/operator helper for granting the first explicit platform admin.
# This is consumed by `pnpm platform-admin grant` when no email argument is passed.
PLATFORM_SUPER_ADMIN_EMAIL=platform@floorconnector.com

# Optional local Playwright credentials for focused super-admin access regression tests.
# Use a real account that has signed in once and has been granted through platform_user_roles.
FLOORCONNECTOR_PLATFORM_E2E_EMAIL=platform@floorconnector.com
FLOORCONNECTOR_PLATFORM_E2E_PASSWORD=

# Optional local Playwright credentials and fixture controls for customer portal QA.
# Use a real Supabase Auth customer account. Do not commit real credentials.
FLOORCONNECTOR_PORTAL_E2E_EMAIL=
FLOORCONNECTOR_PORTAL_E2E_PASSWORD=
PLAYWRIGHT_PORTAL_STORAGE_STATE=playwright/.auth/portal-user.json
FLOORCONNECTOR_ALLOW_E2E_FIXTURE_WRITE=
FLOORCONNECTOR_E2E_PORTAL_PROJECT_PATH=
FLOORCONNECTOR_E2E_PORTAL_ESTIMATE_PATH=
FLOORCONNECTOR_E2E_PORTAL_CONTRACT_PATH=
FLOORCONNECTOR_E2E_PORTAL_INVOICE_PATH=
FLOORCONNECTOR_E2E_PORTAL_UNAUTHORIZED_PROJECT_PATH=

# -----------------------------------------------------------------------------
# Postmark
# -----------------------------------------------------------------------------
POSTMARK_SERVER_TOKEN=
POSTMARK_MESSAGE_STREAM=outbound
POSTMARK_BROADCAST_STREAM=broadcast
POSTMARK_FROM_EMAIL=

# -----------------------------------------------------------------------------
# SignWell
# -----------------------------------------------------------------------------
SIGNWELL_API_KEY=
SIGNWELL_WEBHOOK_SECRET=

# -----------------------------------------------------------------------------
# Google OAuth
# -----------------------------------------------------------------------------
# Supabase Auth remains the runtime auth provider.
# Google credentials are configured in Supabase provider settings and documented
# here so local, staging, and production environments are planned together.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# Email/password auth
# -----------------------------------------------------------------------------
# Email/password uses Supabase Auth and the same shared user model as Google.
# No separate app-side credentials are required, but these runtime URLs must be
# correct so sign-up, callback, and password reset flows work in every env:
# - NEXT_PUBLIC_APP_URL
# - NEXT_PUBLIC_SUPABASE_URL
# - NEXT_PUBLIC_SUPABASE_ANON_KEY
# Provider enablement, site URL, redirect URLs, and email confirmation behavior
# are configured in the Supabase dashboard rather than through app env vars.

# -----------------------------------------------------------------------------
# QuickBooks
# -----------------------------------------------------------------------------
QUICKBOOKS_CLIENT_ID=
QUICKBOOKS_CLIENT_SECRET=
QUICKBOOKS_REDIRECT_URI=
QUICKBOOKS_ENVIRONMENT=sandbox

# -----------------------------------------------------------------------------
# CompanyCam
# -----------------------------------------------------------------------------
COMPANYCAM_CLIENT_ID=
COMPANYCAM_CLIENT_SECRET=
COMPANYCAM_REDIRECT_URI=
COMPANYCAM_WEBHOOK_SECRET=

# -----------------------------------------------------------------------------
# n8n
# -----------------------------------------------------------------------------
N8N_BASE_URL=
N8N_WEBHOOK_URL=
N8N_API_KEY=
