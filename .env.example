# -----------------------------------------------------------------------------
# FloorConnector
# Root environment template for local development and deployed environments.
# Do not commit real secrets to git.
# -----------------------------------------------------------------------------

# -----------------------------------------------------------------------------
# Public app and site URLs
# -----------------------------------------------------------------------------
# Local defaults should use fully qualified localhost URLs.
# Override these in Vercel with your live production domains.
NEXT_PUBLIC_APP_NAME=FloorConnector
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_MARKETING_URL=http://localhost:3000
NEXT_PUBLIC_SUPPORT_URL=http://localhost:3000/support
NEXT_PUBLIC_PRIVACY_POLICY_URL=http://localhost:3000/privacy-policy
NEXT_PUBLIC_TERMS_OF_SERVICE_URL=http://localhost:3000/terms-of-service
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com
NEXT_PUBLIC_SENTRY_DSN=

# -----------------------------------------------------------------------------
# Shared app secrets and runtime configuration
# -----------------------------------------------------------------------------
NODE_ENV=development
APP_ENV=local
APP_SECRET=replace-with-a-long-random-secret
SESSION_SECRET=replace-with-a-long-random-secret
ENCRYPTION_KEY=replace-with-a-32-byte-key
CRON_SECRET=replace-with-a-long-random-secret
INTERNAL_API_TOKEN=replace-with-a-long-random-secret

# -----------------------------------------------------------------------------
# Supabase - development
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL_DEV=
NEXT_PUBLIC_SUPABASE_ANON_KEY_DEV=
SUPABASE_SERVICE_ROLE_KEY_DEV=
SUPABASE_JWT_SECRET_DEV=
SUPABASE_DB_URL_DEV=
SUPABASE_DIRECT_URL_DEV=

# -----------------------------------------------------------------------------
# Supabase - production
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL_PROD=
NEXT_PUBLIC_SUPABASE_ANON_KEY_PROD=
SUPABASE_SERVICE_ROLE_KEY_PROD=
SUPABASE_JWT_SECRET_PROD=
SUPABASE_DB_URL_PROD=
SUPABASE_DIRECT_URL_PROD=

# -----------------------------------------------------------------------------
# Active runtime database and Supabase values used by the app
# Set these to the environment-specific values above in each environment.
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=
DIRECT_URL=

# -----------------------------------------------------------------------------
# Stripe
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CONNECT_WEBHOOK_SECRET=
STRIPE_PRICE_ID_BASE=

# -----------------------------------------------------------------------------
# Postmark
# -----------------------------------------------------------------------------
POSTMARK_SERVER_TOKEN=
POSTMARK_MESSAGE_STREAM=outbound
POSTMARK_BROADCAST_STREAM=broadcast
POSTMARK_FROM_EMAIL=

# -----------------------------------------------------------------------------
# SignWell
# -----------------------------------------------------------------------------
SIGNWELL_API_KEY=
SIGNWELL_WEBHOOK_SECRET=

# -----------------------------------------------------------------------------
# Google OAuth
# -----------------------------------------------------------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# QuickBooks
# -----------------------------------------------------------------------------
QUICKBOOKS_CLIENT_ID=
QUICKBOOKS_CLIENT_SECRET=
QUICKBOOKS_REDIRECT_URI=
QUICKBOOKS_ENVIRONMENT=sandbox

# -----------------------------------------------------------------------------
# CompanyCam
# -----------------------------------------------------------------------------
COMPANYCAM_CLIENT_ID=
COMPANYCAM_CLIENT_SECRET=
COMPANYCAM_REDIRECT_URI=
COMPANYCAM_WEBHOOK_SECRET=

# -----------------------------------------------------------------------------
# n8n
# -----------------------------------------------------------------------------
N8N_BASE_URL=
N8N_WEBHOOK_URL=
N8N_API_KEY=
